# The guest binary (app.bin, consumed by the verifier/prover) and its text
# section (app.text, read by the transpiler) are committed and refreshed via
# /update-vks. app.elf / manifest.toml are unused build byproducts.
guest/dist/*
!guest/dist/app/
guest/dist/app/*
!guest/dist/app/app.bin
!guest/dist/app/app.text
